    },
    {
      "name": "login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Ép kiểu dữ liệu trả về từ Server thành Object JSON\r",
              "const response = pm.response.json();\r",
              "\r",
              "// 2. Kiểm tra nếu Server trả về mã 200 và có chứa trường token\r",
              "if (pm.response.code === 200 && response.token) {\r",
              "    // Tự động gán giá trị token vào biến 'token' của Environment Local Development\r",
              "    pm.environment.set(\"token\", response.token);\r",
              "    console.log(\"✅ [Postman Script]: Đã tự động cập nhật JWT Token mới vào Environment!\");\r",
              "} else {\r",
              "    console.log(\"❌ [Postman Script]: Không tìm thấy Token trong phản hồi.\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"user1\",\r\n  \"email\": \"user1@gmail.com\",\r\n  \"password\": \"111111\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    }
  ]
}